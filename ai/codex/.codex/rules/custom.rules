# Python
prefix_rule(pattern=["pytest"], decision="allow")
prefix_rule(pattern=["python", "-m", "pytest"], decision="allow")
prefix_rule(pattern=["python3", "-m", "pytest"], decision="allow")
prefix_rule(pattern=["uv", "run"], decision="allow")
prefix_rule(pattern=["ruff"], decision="allow")
prefix_rule(pattern=["mypy"], decision="allow")
prefix_rule(pattern=["flake8"], decision="allow")
prefix_rule(pattern=["pylint"], decision="allow")

# JavaScript / TypeScript
prefix_rule(pattern=["eslint"], decision="allow")
prefix_rule(pattern=["npx", "eslint"], decision="allow")
prefix_rule(pattern=["tsc"], decision="allow")
prefix_rule(pattern=["bun", "test"], decision="allow")
prefix_rule(pattern=["bun", "run"], decision="allow")
prefix_rule(pattern=["pnpm", "test"], decision="allow")
prefix_rule(pattern=["pnpm", "run"], decision="allow")
prefix_rule(pattern=["yarn", "test"], decision="allow")
prefix_rule(pattern=["biome"], decision="allow")
prefix_rule(pattern=["prettier"], decision="allow")

# Go
prefix_rule(pattern=["go", "test"], decision="allow")
prefix_rule(pattern=["go", "vet"], decision="allow")
prefix_rule(pattern=["golangci-lint"], decision="allow")

# Rust
prefix_rule(pattern=["cargo", "test"], decision="allow")
prefix_rule(pattern=["cargo", "clippy"], decision="allow")

# Ruby
prefix_rule(pattern=["rubocop"], decision="allow")
prefix_rule(pattern=["bundle", "exec"], decision="allow")

# Deno
prefix_rule(pattern=["deno", "test"], decision="allow")
prefix_rule(pattern=["deno", "lint"], decision="allow")
